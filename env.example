# PULSE BOT — Environment Variables
# Copy this file to .env and fill in your values
# NEVER share your .env file or commit it to GitHub

# ─── Telegram ────────────────────────────────────────────────
# Your Telegram Bot Token from @BotFather
TELEGRAM_TOKEN=your_telegram_bot_token_here

# Your Telegram Channel ID where the bot posts alerts
# Format: @yourchannel  OR  -1001234567890 (numeric ID for private channels)
TELEGRAM_CHANNEL_ID=@yourchannel

# Admin user IDs — only these 2 users can command the bot privately
# To get your ID: message @userinfobot on Telegram
ADMIN_1_ID=your_telegram_user_id_here
ADMIN_2_ID=second_admin_user_id_here

# ─── Scheduler intervals ─────────────────────────────────────
SIGNAL_CHECK_INTERVAL=15
TREND_CHECK_INTERVAL=30

# ─── AI-Powered Ideas (Claude API) ───────────────────────────
# Get your key at: https://console.anthropic.com
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ─── Timezone ────────────────────────────────────────────────
# Default timezone for scheduled alerts
# Examples: Africa/Lagos, America/New_York, Europe/London, Asia/Tokyo
DEFAULT_TIMEZONE=Africa/Lagos
